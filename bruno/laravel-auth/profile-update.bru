meta {
  name: Update Profile
  type: http
  seq: 4
}

put {
  url: {{laravel_base}}/api/v1/auth/profile
  body: json
  auth: bearer
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  "district": "Entebbe",
  "education_level": "tertiary"
}

auth:bearer {
  token: {{token}}
}
